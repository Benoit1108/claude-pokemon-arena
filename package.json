{
  "name": "claude-pokemon-arena",
  "version": "0.1.0",
  "private": true,
  "description": "Web arena for claude-pokemon — leaderboard, trainer cards, async battles",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "format": "prettier --write '**/*.{vue,ts,js,json,md}'",
    "format:check": "prettier --check '**/*.{vue,ts,js,json,md}'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.0.0",
    "@nuxt/test-utils": "^4.0.3",
    "@nuxtjs/color-mode": "^4.0.0",
    "@unocss/nuxt": "^66.0.0",
    "@unocss/preset-wind4": "^66.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^9.0.0",
    "happy-dom": "^20.9.0",
    "nuxt": "^4.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0",
    "vue-tsc": "^2.0.0"
  }
}
